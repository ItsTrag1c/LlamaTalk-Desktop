{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LlamaTalk Desktop",
  "version": "0.12.0",
  "identifier": "com.claudetractor.llamachatv1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LlamaTalk Desktop",
        "width": 1100,
        "height": 740,
        "minWidth": 720,
        "minHeight": 500,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' https://tauri.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src ipc: http://ipc.localhost; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "resources": ["resources/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/installer-icon.ico",
        "installMode": "perMachine",
        "installerHooks": "../installer-hooks.nsi"
      }
    }
  }
}
